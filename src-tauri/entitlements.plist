<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Hardened-runtime resource-access entitlements. The webcam preview
	     bubble reaches the camera via getUserMedia in the WKWebView, and the
	     engine captures the mic; under hardened runtime both are blocked
	     without these. TCC still governs the actual user grant on top. -->
	<key>com.apple.security.device.camera</key>
	<true/>
	<key>com.apple.security.device.audio-input</key>
	<true/>
</dict>
</plist>
