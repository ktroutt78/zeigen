{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main, webcam-bubble, and review windows",
  "windows": ["main", "webcam-bubble", "review-*", "countdown", "timer-chip", "identify-*", "marquee-*", "area-indicator"],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-reveal-item-in-dir",
    "opener:allow-open-url",
    "core:webview:allow-create-webview-window",
    "core:webview:allow-webview-close",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:window:allow-hide",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:window:allow-set-position",
    "core:window:allow-set-size",
    "core:window:allow-set-always-on-top",
    "core:window:allow-set-visible-on-all-workspaces",
    "core:window:allow-set-ignore-cursor-events",
    "core:window:allow-start-dragging",
    "global-shortcut:default",
    "dialog:allow-ask"
  ]
}
